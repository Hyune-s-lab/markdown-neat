<idea-plugin>
    <id>dev.hyunelab.markneat</id>
    <name>MarkNeat</name>
    <vendor url="https://github.com/Hyune-s-lab">Hyune-s-lab</vendor>

    <description><![CDATA[
        <p>A lightweight, read-only Markdown viewer for JetBrains IDEs.</p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileEditorProvider implementation="dev.hyunelab.markneat.editor.MarkNeatFileEditorProvider"/>
        <applicationService serviceImplementation="dev.hyunelab.markneat.settings.MarkNeatSettings"/>
        <applicationConfigurable
                parentId="tools"
                id="dev.hyunelab.markneat.settings"
                displayName="MarkNeat"
                instance="dev.hyunelab.markneat.settings.MarkNeatSettingsConfigurable"/>
    </extensions>
</idea-plugin>
